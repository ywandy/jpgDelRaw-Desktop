{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RAW Pair Cleaner",
  "version": "1.0.1",
  "identifier": "com.ywandy.rawpaircleaner",
  "build": {
    "beforeDevCommand": "pnpm vite --host 127.0.0.1",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RAW Pair Cleaner / 底片清理器",
        "width": 1200,
        "height": 820,
        "minWidth": 1200,
        "minHeight": 720,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 22,
          "y": 18
        },
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "targets": [
      "app"
    ],
    "createUpdaterArtifacts": true,
    "category": "Photography",
    "shortDescription": "RAW Pair Cleaner",
    "longDescription": "Safely find unmatched JPG-like and RAW photo files and move selected redundancies to the system trash.",
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhEMDFDRUUzODUzQzZCMTMKUldRVGF6eUY0ODRCalM4WGdMZUMreEwxSG5qZ0FoWjFhSGZhWVQ2SnpjZmlSNHVHV3N3RWcyZTIK",
      "endpoints": [
        "https://github.com/ywandy/jpgDelRaw-Desktop/releases/latest/download/latest.json"
      ]
    }
  }
}
