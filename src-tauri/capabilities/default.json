{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Desktop app permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "dialog:allow-open",
    "os:allow-platform",
    "process:allow-restart",
    "updater:allow-check",
    "updater:allow-download-and-install"
  ]
}
