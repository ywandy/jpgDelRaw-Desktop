{
  "name": "raw-pair-cleaner",
  "version": "1.0.3",
  "description": "RAW Pair Cleaner / 底片清理器",
  "author": {
    "name": "ywandy",
    "email": "ywandy@users.noreply.github.com"
  },
  "main": "dist-electron/electron/main.js",
  "build": {
    "appId": "com.ywandy.rawpaircleaner",
    "productName": "RAW Pair Cleaner",
    "directories": {
      "output": "release"
    },
    "asar": true,
    "compression": "maximum",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.photography",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.icns",
      "publish": null
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico",
      "publish": null
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Graphics",
      "icon": "build/icon.png",
      "publish": null
    },
    "extraResources": [
      {
        "from": "scripts/updater-helper.mjs",
        "to": "updater/updater-helper.mjs"
      }
    ],
    "publish": null
  },
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"tsc -p tsconfig.node.json --watch --preserveWatchOutput\" \"wait-on http://127.0.0.1:5173 dist-electron/electron/main.js && electron .\"",
    "build": "tsc -p tsconfig.node.json && tsc -p tsconfig.json --noEmit && vite build",
    "dist": "pnpm build && electron-builder --publish never",
    "dist:dir": "pnpm build && electron-builder --dir",
    "start": "electron .",
    "test": "vitest run",
    "version:check": "node scripts/check-version.mjs",
    "manifest:asar": "node scripts/generate-asar-manifest.mjs",
    "version:apply-tag": "node scripts/apply-tag-version.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "lucide-react": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "autoprefixer": "^10.4.20",
    "concurrently": "latest",
    "electron": "latest",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest",
    "wait-on": "latest"
  }
}
